<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>3 en Raya</title>
<style>
  body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    text-align: center;
    margin-top: 50px;
    background: #f0f4f8;
    color: #333;
  }

  h1 {
    margin-bottom: 20px;
    color: #2c3e50;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.2);
  }

  #board {
    display: grid;
    grid-template-columns: repeat(3, 100px);
    grid-gap: 10px;
    justify-content: center;
    margin-bottom: 20px;
  }

  .cell {
    width: 100px;
    height: 100px;
    font-size: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border-radius: 15px;
    border: 2px solid #2980b9;
    background: #ecf0f1;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    transition: all 0.2s ease;
  }

  .cell:hover {
    background: #d0e6f7;
    transform: scale(1.1);
  }

  #resetBtn {
    padding: 10px 25px;
    font-size: 18px;
    border: none;
    border-radius: 10px;
    background: #2980b9;
    color: white;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  #resetBtn:hover {
    background: #3498db;
    transform: scale(1.05);
  }

  #status {
    font-size: 20px;
    margin-top: 15px;
    font-weight: bold;
    color: #34495e;
  }

  /* Diferenciar X y O */
  .cell.x {
    color: #e74c3c;
  }

  .cell.o {
    color: #27ae60;
  }
</style>
</head>
<body>

<h1>3 en Raya</h1>
<div id="board"></div>
<button id="resetBtn">Reiniciar</button>
<p id="status"></p>

<script>
  const board = document.getElementById('board');
  const status = document.getElementById('status');
  let currentPlayer = 'X';
  let gameOver = false;
  let cells = [];

  // Crear tablero
  for (let i = 0; i < 9; i++) {
    const cell = document.createElement('div');
    cell.classList.add('cell');
    cell.addEventListener('click', () => makeMove(i));
    board.appendChild(cell);
    cells.push(cell);
  }

  function makeMove(index) {
    // pequeño cambio: registrar en consola el intento de movimiento
    console.log(`makeMove called for index ${index} by player ${currentPlayer}`);
    if (cells[index].textContent === '' && !gameOver) {
      cells[index].textContent = currentPlayer;
      if (checkWin(currentPlayer)) {
        status.textContent = `¡Jugador ${currentPlayer} gana!`;
        gameOver = true;
      } else if (cells.every(cell => cell.textContent !== '')) {
        status.textContent = "¡Empate!";
        gameOver = true;
      } else {
        currentPlayer = currentPlayer === 'X' ? 'O' : 'X';
        status.textContent = `Turno de ${currentPlayer}`;
      }
    }
  }
// Método más limpio para verificar ganador
function checkWin(player) {
  const wins = [
    [0,1,2],[3,4,5],[6,7,8], // filas
    [0,3,6],[1,4,7],[2,5,8], // columnas
    [0,4,8],[2,4,6]          // diagonales
  ];
  // Devuelve la combinación ganadora si existe, o false
  return wins.find(combo => combo.every(i => cells[i].textContent === player)) || false;
}

// Resetear tablero con animación sutil
document.getElementById('resetBtn').addEventListener('click', () => {
  cells.forEach(cell => {
    cell.textContent = '';
    cell.style.backgroundColor = '';
    cell.style.color = '';
    cell.style.transform = 'scale(1)';
  });
  currentPlayer = 'X';
  gameOver = false;
  status.textContent = `Turno de ${currentPlayer}`;
});

  status.textContent = `Turno de ${currentPlayer}`;
</script>

</body>
</html>
